{
  "name": "gitlab-copilot",
  "version": "2.0.0",
  "description": "GitLab MR code review using GitHub Copilot SDK on GitLab CI",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.mjs --format=esm --external:@github/copilot-sdk",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "gitlab",
    "copilot",
    "code-review",
    "ci"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.29"
  }
}
